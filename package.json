{
  "name": "@innet/jsx-runtime",
  "version": "1.0.2",
  "description": "JSX runtime for Innet",
  "author": "Mikhail Lysikov <d8corp@mail.ru>",
  "license": "MIT",
  "main": "jsx-runtime.js",
  "module": "jsx-runtime.mjs",
  "jsnext:main": "jsx-runtime.mjs",
  "types": "jsx-runtime.d.ts",
  "exports": {
    ".": {
      "import": "./jsx-runtime.mjs",
      "require": "./jsx-runtime.js"
    },
    "./jsx-runtime": {
      "import": "./jsx-runtime.mjs",
      "require": "./jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "import": "./jsx-dev-runtime.mjs",
      "require": "./jsx-dev-runtime.js"
    }
  },
  "private": true,
  "homepage": "https://github.com/d8corp/innet-jsx-runtime",
  "bugs": {
    "url": "https://github.com/d8corp/innet-jsx-runtime/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/d8corp/innet-jsx-runtime.git"
  },
  "keywords": [
    "innet",
    "jsx",
    "runtime",
    "react",
    "reactive",
    "front-end"
  ],
  "scripts": {
    "build": "innetjs release -i \"{jsx-runtime,jsx-dev-runtime}\"",
    "test": "npm run test:jest && npm run test:size",
    "test:jest": "jest",
    "test:coverage": "jest --coverage",
    "release": "innetjs release -p -i \"{jsx-runtime,jsx-dev-runtime}\"",
    "patch": "innetjs patch",
    "minor": "innetjs minor",
    "major": "innetjs major",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "dependencies": {
    "@innet/jsx": "^2.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "@typescript-eslint/parser": "^8.55.0",
    "core-js": "^3.30.1",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.14.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "innetjs": "^3.1.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "neostandard": "^0.12.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}
